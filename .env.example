# Jeepay UI project root. This repo keeps jeepay-ui under ./jeepay-ui by default.
UI_BASE_DIR=.

# 预构建镜像：默认从 GHCR 拉取，低配服务器无需现场编译。
# 想本地编译（改了代码/无法访问 GHCR）：把 IMAGE_PREFIX 注释掉或改为本地名（如 yunpay），
# compose 会自动用 build 段构建。
IMAGE_PREFIX=ghcr.io/shengtong1/yunpay
IMAGE_TAG=latest

# 基础镜像（本地构建时使用）。默认走国内镜像加速，按需覆盖。
MYSQL_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/mysql:8.0
MAVEN_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/maven:3.9-eclipse-temurin-17
NODE_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/node:20-alpine
NGINX_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/nginx:alpine
JAVA_BASE_IMAGE=docker.1ms.run/library/eclipse-temurin:17-jre
JEEPAY_PAY_API_URL=http://payment:9216
JEEPAY_MGR_NOTIFY_URL=http://manager:9217
